# Copy to `.env` and adjust. Flask loads these from the environment.

# OpenAI (optional for Interview Simulator — without it, mock mode is used)
OPENAI_API_KEY=

# Force deterministic mock responses (no API calls)
# INTERVIEW_SIMULATOR_MOCK=1

# Model for interview simulator endpoints (when not in mock)
# INTERVIEW_SIMULATOR_MODEL=gpt-4.1-mini
